# Copy this file to .env and fill in at least one LLM key.
# Only one is required — use whichever provider you have access to.

# Google Gemini (recommended — free tier available)
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Ollama runs locally — no key needed. Set the URL if not default.
# OLLAMA_BASE_URL=http://localhost:11434
